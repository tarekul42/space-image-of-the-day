    "@types/node": "^25.5.0",
    "@types/pino": "^7.0.5",
    "@types/redis": "^4.0.11",
    "eslint": "^10.1.0",
    "typescript-eslint": "^8.58.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
